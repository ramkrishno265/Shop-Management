generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

model Shop {
  id        Int      @id @default(autoincrement())
  name      String?
  logo      String?
  phone     String?
  email     String?
  address   String?
  status    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]
  products  Product[]
  invoices  Invoice[]

  @@map("shops")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String
  password  String
  photo     String?
  status    Boolean  @default(true)
  role      Role     @default(CASHIER)
  
  shopId    Int      
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  lastLogin DateTime? @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  invoices  Invoice[]
  stockLogs StockLog[] // কে স্টক আপডেট করেছে তার রেকর্ড রাখার জন্য

  @@map("users")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  products  Product[]
}

model Product {
  id            Int       @id @default(autoincrement())
  name          String
  sku           String?   @unique
  
  quantity      Float     @default(0)
  unit          String
  lowStockLimit Float     @default(5)

  purchasePrice Float
  sellingPrice  Float

  categoryId    Int?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  shopId        Int
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  description   String?
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  salesItems    SalesItem[]
  stockLogs     StockLog[]  // প্রোডাক্টের স্টক হিস্ট্রি রিলেশন
}

// স্টক আপডেট এবং ডেটা সুরক্ষার জন্য অডিট লগ টেবিল
model StockLog {
  id              Int      @id @default(autoincrement())
  productId       Int
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  userId          Int?     // কে স্টক আপডেট করেছে (Admin/Manager)
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  changeType      String   // যেমন: 'RESTOCK', 'SALE', 'DAMAGE', 'ADJUSTMENT'
  quantityChanged Float    // কত পরিমাণ যোগ বা বিয়োগ হলো
  previousStock   Float    // আগের স্টক
  newStock        Float    // বর্তমান স্টক
  note            String?  // নোট বা কারণ

  createdAt       DateTime @default(now()) @map("created_at")

  @@map("stock_logs")
}

model Invoice {
  id            Int         @id @default(autoincrement())
  invoiceNumber String      @unique
  cashierId     Int
  cashier       User        @relation(fields: [cashierId], references: [id])
  totalAmount   Float
  discount      Float       @default(0.0)
  payableAmount Float
  paymentMethod String      @default("CASH")
  createdAt     DateTime    @default(now())
  items         SalesItem[]

  shopId        Int
  shop          Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model SalesItem {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  quantity  Int
  unitPrice Float
}